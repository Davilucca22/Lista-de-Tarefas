{
  "manifest_version": 3,
  "name": "Lembrei",
  "version": "1.0",
  "description": "Extrai e salva o conteúdo de páginas visitadas.",
  "permissions": ["activeTab", "scripting", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Lembrei"
  }
}
